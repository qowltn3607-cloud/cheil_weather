{
  "version": 2,
  "builds": [
    { "src": "api/weather.js", "use": "@vercel/node" },
    { "src": "api/outfit.js",  "use": "@vercel/node" },
    { "src": "public/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/weather", "dest": "/api/weather.js" },
    { "src": "/api/outfit",  "dest": "/api/outfit.js"  },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
